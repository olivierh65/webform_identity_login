<?php

use Drupal\webform_identity_login\Utils\HmacUtils;
use Drupal\Core\Form\FormStateInterface;

/**
 * @file
 * Webform Identity Login module.
 */

/**
 * Implements hook_theme().
 */
function webform_identity_login_theme($existing, $type, $theme, $path) {
  return [
    'identity_login_composite' => [
      'render element' => 'element',
      'path' => $path . '/templates',
      'template' => 'identity_login_composite',
    ],
    'webform_handler_identity_login_handler_summary' => [
      'variables' => [
        'settings' => NULL,
        'handler' => [],
      ],
      'path' => $path . '/templates',
      'template' => 'webform-handler-identity-login-handler-summary',
    ],
  ];
}


/**
 * Implements hook_civicrm_tokens().
 */
function webform_identity_login_civicrm_tokens(&$tokens) {
  // Déclarer dynamiquement un token par webform configuré.
  try {
    $webform_storage = \Drupal::entityTypeManager()->getStorage('webform');
    $webforms = $webform_storage->loadMultiple();

    foreach ($webforms as $webform) {
      $elements = $webform->getElementsDecodedAndFlattened();

      foreach ($elements as $element) {
        if (($element['#type'] ?? NULL) !== 'identity_login_composite') {
          continue;
        }
        if (empty($element['#secret_key'])) {
          continue;
        }

        $tokens['identity_login']['identity_login.url_' . $webform->id()]
          = t('Identity Login URL - @label', ['@label' => $webform->label()]);

        break;
      }
    }
  }
  catch (\Exception $e) {
    // Silencieux si Drupal n'est pas encore bootstrappé.
  }
}

/**
 * Implements hook_civicrm_tokenValues().
 */
function webform_identity_login_civicrm_tokenValues(&$values, $cids, $job = NULL, $tokens = [], $context = NULL) {
  // Vérifier si un de nos tokens est demandé.
  $our_tokens = $tokens['identity_login'] ?? [];
  if (empty($our_tokens)) {
    return;
  }

  try {
    $webform_storage = \Drupal::entityTypeManager()->getStorage('webform');
    $webforms = $webform_storage->loadMultiple();

    // Construire la map webform_id => config.
    $configs = [];
    foreach ($webforms as $webform) {
      $elements = $webform->getElementsDecodedAndFlattened();
      foreach ($elements as $element) {
        if (($element['#type'] ?? NULL) !== 'identity_login_composite') {
          continue;
        }
        $secret_key = $element['#secret_key'] ?? '';
        if (empty($secret_key)) {
          continue;
        }
        $configs[$webform->id()] = [
          'secret_key' => $secret_key,
          'url' => \Drupal::request()->getSchemeAndHttpHost()
            . $webform->toUrl('canonical')->toString(),
        ];
        break;
      }
    }

    // Pour chaque contact, générer les valeurs des tokens.
    foreach ($cids as $cid) {
      foreach ($our_tokens as $token_name) {
        if (!str_starts_with($token_name, 'url_')) {
          continue;
        }

        $webform_id = substr($token_name, 4);
        if (!isset($configs[$webform_id])) {
          continue;
        }

        $secret_key = $configs[$webform_id]['secret_key'];
        $url        = $configs[$webform_id]['url'];
        $token      = HmacUtils::computeHmac($cid ?? 'Non trouve', $values[$cid]['first_name'] ?? '', $values[$cid]['last_name'] ?? '', $values[$cid]['email'] ?? '', $secret_key);

        $values[$cid]['identity_login.' . $token_name] = $url . '?' . http_build_query([
          'idtoken' => $token,
        ]);
      }
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('webform_identity_login')->error(
      'Erreur tokenValues : @msg', ['@msg' => $e->getMessage()]
    );
  }
}

/**
 * Implements hook_views_data().
 */
function webform_identity_login_views_data() {

  $data['webform_submission']['webform_identity_token'] = [
    'title' => t('Webform Identity Token'),
    'help' => t('Computed identity token for this submission'),
    'field' => [
      'id' => 'webform_identity_token',
      'click sortable' => FALSE,
    ],
    'real field' => 'sid',  // pointe vers une colonne qui existe réellement
  ];

  $data['webform_submission']['webform_identity_login_url'] = [
    'title' => t('Webform Identity Login URL'),
    'help' => t('URL with identity token to access the webform.'),
    'field' => [
      'id' => 'webform_identity_login_url',
      'click sortable' => FALSE,
    ],
    'real field' => 'sid',
  ];

  // La clé views est la table "virtuelle" que Drupal Views utilise pour les champs globaux
  $data['views']['identity_login_url_from_fields'] = [
    'title' => t('Identity Login URL (from fields)'),
    'help' => t('Computed identity login URL built from selected view fields.'),
    'field' => [
      'id' => 'identity_login_url_from_fields',
      'click sortable' => FALSE,
    ],
  ];
  return $data;
}

/**
 * Implements hook_views_query_alter().
 *
 * Corrige les JOIN buggés générés par Webform pour les sous-champs composites.
 * Le bug : Views génère AND property = 'last_name' AND property = ''
 * ce qui rend la condition impossible (0 lignes → doublons).
 */
function webform_identity_login_views_query_alter(\Drupal\views\ViewExecutable $view, \Drupal\views\Plugin\views\query\QueryPluginBase $query) {
  if (!$query instanceof \Drupal\views\Plugin\views\query\Sql) {
    return;
  }

  if (($view->storage->get('base_table') ?? '') !== 'webform_submission') {
    return;
  }

  // Corriger les JOINs buggés (property = '').
  try {
    $reflection = new \ReflectionClass($query);
    if (!$reflection->hasProperty('tableQueue')) {
      return;
    }
    $prop = $reflection->getProperty('tableQueue');
    $prop->setAccessible(TRUE);
    $table_queue = $prop->getValue($query);
  }
  catch (\ReflectionException $e) {
    return;
  }

  if (!is_array($table_queue) || empty($table_queue)) {
    return;
  }

  $modified = FALSE;
  foreach ($table_queue as $alias => &$table_info) {
    if (empty($table_info['join'])) {
      continue;
    }
    $join = $table_info['join'];
    if (!isset($join->extra) || !is_array($join->extra)) {
      continue;
    }
    $has_property_value = FALSE;
    $has_property_empty = FALSE;
    $empty_index = NULL;
    foreach ($join->extra as $i => $extra) {
      if (($extra['field'] ?? '') === 'property') {
        if (($extra['value'] ?? '') === '') {
          $has_property_empty = TRUE;
          $empty_index = $i;
        }
        else {
          $has_property_value = TRUE;
        }
      }
    }
    if ($has_property_value && $has_property_empty && $empty_index !== NULL) {
      unset($join->extra[$empty_index]);
      $join->extra = array_values($join->extra);
      $modified = TRUE;
    }
  }

  if ($modified) {
    $prop->setValue($query, $table_queue);
  }

  // Remplacer la requête principale par une sous-requête qui ne garde
  // que le MAX(sid) par email (dernière soumission par contact).
  // On injecte une condition sur sid via une sous-requête.
  // Récupérer les webform_ids depuis le filtre 'webform_id' (filtre bundle).
  $webform_ids = [];
  foreach ($view->filter ?? [] as $filter_id => $filter) {
    if ($filter_id === 'webform_id' && isset($filter->value) && is_array($filter->value)) {
      $webform_ids = array_keys($filter->value);
      break;
    }
  }

  if (empty($webform_ids)) {
    return;
  }

  // Sous-requête : MAX(sid) par email = dernière soumission par contact.
  $db = \Drupal::database();
  $subquery = $db->select('webform_submission_data', 'wsd_email')
    ->condition('wsd_email.webform_id', $webform_ids, 'IN')
    ->condition('wsd_email.name', 'identite')
    ->condition('wsd_email.property', 'email')
    ->condition('wsd_email.delta', '0')
    ->groupBy('wsd_email.value');
  $subquery->addExpression('MAX(wsd_email.sid)', 'max_sid');

  $max_sids = $subquery->execute()->fetchCol();

  if (!empty($max_sids)) {
    $query->addWhere(0, 'webform_submission.sid', $max_sids, 'IN');
  }
}
